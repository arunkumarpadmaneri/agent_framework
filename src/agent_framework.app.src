{application, agent_framework,
 [
  {description, "Multi-agent orchestration framework with LLM integration"},
  {vsn, "1.0.0"},
  {modules,
   [%% Public API
    agent_framework,
    %% OTP application & supervisor
    agent_framework_app,
    agent_framework_sup,
    %% Orchestration pipeline
    agent_executor,
    agent_formatter,
    agent_intent,
    agent_orchestrator,
    agent_planner,
    agent_react,
    %% Agent management
    agent_registry,
    %% LLM adapters & router
    llm_claude,
    llm_gemini,
    llm_groq,
    llm_http,
    llm_openai,
    llm_router,
    llm_test_adapter,
    %% Tool registry
    test_tools,
    tool_registry,
    %% Library utilities
    af_config,
    af_error,
    af_lib,
    af_logger,
    rate_limiter,
    session_mgr,
    %% Workflow pattern helpers (project uses these in their domain module)
    workflow_constants]},
  {registered, []},
  {applications, [kernel, stdlib, crypto, ssl, inets, jsx]},
  {env, []},
  {mod, {agent_framework_app, []}},
  {links, []}
 ]}.
