    llm_gemini,
    llm_openai,
    llm_router,
    mis_tools,
    rate_limiter,
    session_mgr,
    tool_registry]},
  {registered, []},
  {applications, [kernel, stdlib, crypto, ssl, inets, jsx]},
  {env, []},
  {mod, {agent_framework_app, []}},
  {links, []}
 ]}.
