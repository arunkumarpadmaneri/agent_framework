%% =============================================================================
%% rebar.config
%% agent_framework — multi-agent orchestration library
%% Add this as a dep in your existing application's rebar.config
%% =============================================================================
{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
  {jsx, "3.1.0"}
  %% poolboy available if you need connection pooling to MCP servers
  %% {poolboy, "1.5.2"}
]}.

{shell, [
  {config, "config/sys.config"},
  {apps,   [agent_framework]}
]}.
