%% =============================================================================
%% config/sys.config
%%
%% Generic Agent Framework Configuration
%%
%% This framework is domain-agnostic. Domain-specific agents, tools, and prompts
%% are loaded from domain-specific config files in config/domains/
%%
%% Each domain config defines:
%%   - Agent IDs, descriptions, and workflows
%%   - Tool lists and tool schemas
%%   - Custom prompts (intent_prompt, format_prompt)
%%   - LLM profile assignments
%%
%% No code changes needed to:
%%   - Add new domains
%%   - Add new agents within a domain
%%   - Change LLM providers or models
%%   - Modify tool configurations
%% =============================================================================
[
  {agent_framework, [

    %% ── LLM PROVIDER PROFILES ────────────────────────────────────────────────
    %% Named profiles — referenced by agents in their step configs.
    %% Add as many profiles as you need (different models, keys, temperatures).
    {llm_profiles, [
      {claude_standard, [
        {provider,    claude},
        {api_key,     {env, "ANTHROPIC_API_KEY"}},
        {model,       "claude-sonnet-4-20250514"},
        {max_tokens,  2048},
        {temperature, 0.0},
        {timeout_ms,  30000}
      ]},
      {claude_fast, [
        {provider,    claude},
        {api_key,     {env, "ANTHROPIC_API_KEY"}},
        {model,       "claude-haiku-4-5-20251001"},   %% faster, cheaper
        {max_tokens,  1024},
        {temperature, 0.0},
        {timeout_ms,  15000}
      ]},
      {openai_standard, [
        {provider,    openai},
        {api_key,     {env, "OPENAI_API_KEY"}},
        {model,       "gpt-4o"},
        {max_tokens,  2048},
        {temperature, 0.0},
        {timeout_ms,  30000}
      ]},
      {gemini_standard, [
        {provider,    gemini},
        {api_key,     {env, "GEMINI_API_KEY"}},
        {model,       "gemini-1.5-pro"},
        {max_tokens,  2048},
        {temperature, 0.0},
        {timeout_ms,  30000}
      ]}
    ]},

    %% ── AGENTS (from domain configs) ──────────────────────────────────────────
    %% Agents are loaded from domain-specific config files.
    %% Each domain defines its own agents with custom prompts and tool lists.
    %% Format: {agents, Domains} where Domains is a list of config file references
    %%
    %% Example: To load hospital domain agents, ensure config/domains/hospital.config exists
    {agents, []},  %% Loaded from domain configs at runtime

    %% ── PIPELINE SETTINGS ────────────────────────────────────────────────────
    {pipeline_timeout_ms, 60000},
    {retry_attempts,      3},
    {retry_base_ms,       1000},
    {session_ttl_seconds, 1800},
    {max_parallel_tools,  5}
  ]},

  {kernel, [
    {logger_level, info},
    {logger, [{handler, default, logger_std_h, #{
      formatter => {logger_formatter, #{
        template => [time, " [", level, "] ", msg, "\n"]
      }}
    }}]}
  ]}
].

