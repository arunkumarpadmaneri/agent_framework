%% =============================================================================
%% config/sys.config  —  FRAMEWORK DEFAULTS (standalone / development use)
%%
%% All keys below have built-in defaults in src/lib/af_config.erl.
%% You do NOT need to copy all of this into your project.
%%
%% In your project's sys.config, include ONLY the keys you want to override:
%%
%%   [{agent_framework, [
%%       {tool_modules,  [my_hims_tools, my_mis_tools]},
%%       {llm_profiles,  [{my_fast_llm, [{provider, groq}, ...]}]},
%%       {pipeline_timeout_ms, 30000}
%%       %% everything else uses af_config.erl defaults automatically
%%   ]}].
%%
%% LLM PROFILES
%%   Your project's profiles MERGE with the built-in profiles (claude_standard,
%%   claude_fast, openai_standard, gemini_standard, groq_standard).
%%   To disable built-ins entirely: {llm_profiles_builtin, false}
%%   To override a built-in: define a profile with the same name.
%%
%% SINGLE KEY OVERRIDE AT RUNTIME (no restart needed):
%%   application:set_env(agent_framework, retry_attempts, 5).
%% =============================================================================
[
  {agent_framework, [

    %% ── LLM PROVIDER PROFILES ────────────────────────────────────────────────
    %% Built-in profiles (claude_standard, claude_fast, openai_standard,
    %% gemini_standard, groq_standard) are always available via af_config.erl.
    %% Add your own profiles here — they take precedence over built-ins.
    {llm_profiles, []},

    %% ── DOMAIN MODULE ────────────────────────────────────────────────────────
    %% Your project's constants module — set this in your project's sys.config.
    %% The module must export agents/0 and optionally llm_profiles/0.
    %% Copy test/domain_constants_example.erl as a starting point.
    %%
    %%   {domain_module, my_hospital_constants}
    %%
    %% Not set here — framework loads no agents by default.

    %% ── AGENTS (inline, optional) ─────────────────────────────────────────
    %% Alternative to domain_module: define agents directly in sys.config.
    {agents, []},

    %% ── TOOL MODULES ─────────────────────────────────────────────────────────
    %% Modules that expose tool schemas via schemas/0.
    %% Your project sets this to its own tool modules.
    {tool_modules, []},

    %% ── PIPELINE SETTINGS ────────────────────────────────────────────────────
    %% Shown here for reference — all have defaults in af_config.erl.
    %% Uncomment and change only what you need.
    %%
    %% {pipeline_timeout_ms,   60000},
    %% {retry_attempts,        3},
    %% {retry_base_ms,         1000},
    %% {session_ttl_seconds,   1800},
    %% {max_parallel_tools,    5},
    %% {react_max_iterations,  5},
    %%
    %% Disable built-in LLM profiles (use only your own):
    %% {llm_profiles_builtin,  false}

    %% ── DUMMY PLACEHOLDER ────────────────────────────────────────────────────
    %% Keeps the proplist non-empty so OTP doesn't complain.
    {llm_profiles_builtin, true}
  ]},

  {kernel, [
    {logger_level, info},
    {logger, [{handler, default, logger_std_h, #{
      formatter => {logger_formatter, #{
        template => [time, " [", level, "] ", msg, "\n"]
      }}
    }}]}
  ]}
].
